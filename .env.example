# Supabase Configuration (CLIENT-SAFE - exposed to browser)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (SERVER-SIDE ONLY - NEVER use VITE_ prefix)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Firebase Cloud Messaging Configuration (SERVER-SIDE ONLY - NEVER use VITE_ prefix)
# CRITICAL: These are ONLY used in Vercel API routes (api/notifications/send.ts)
# Get these credentials from Firebase Console:
# 1. Go to Project Settings > Service Accounts
# 2. Click "Generate new private key"
# 3. Extract the values from the downloaded JSON file

# Project ID (from Firebase Console)
FIREBASE_PROJECT_ID=music-app-10f66

# Service Account Private Key (from the downloaded JSON file)
# Keep the quotes and use \\n for newlines
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Service Account Client Email (from the downloaded JSON file)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@music-app-10f66.iam.gserviceaccount.com

# WARNING: NEVER use VITE_ prefix for server-only secrets!
# VITE_ variables are bundled into the client and visible to anyone who opens DevTools
